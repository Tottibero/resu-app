const badgeMap: Record<string, string> = {};
const genreMap: Record<string, string> = {};
for (const day of days) {
  for (const stage of day.stages) {
    for (const band of stage.bands) {
      if (band.badge) badgeMap[band.name] = band.badge;
      if (band.genre) genreMap[band.name] = band.genre.replace(' (Set Especial)', '').replace(' (Ganador concurso)', '');
    }
  }
}

const scheduleMap: Record<string, { start: string; end: string }> = {};
for (const stages of Object.values(schedule)) {
  for (const bands of Object.values(stages)) {
    for (const band of bands) {
      scheduleMap[band.name] = { start: band.start, end: band.end };
    }
  }
}

const processedSchedule = Object.fromEntries(
  Object.entries(schedule).map(([day, sched]) => [day, processDay(sched, badgeMap)])
);
