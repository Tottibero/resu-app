<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resurrection Fest MMXXVI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow+Condensed:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:   #f0ece3;
      --card:    #faf9f5;
      --card2:   #f3f0e8;
      --border:  #e0dbd0;
      --border2: #ccc8be;
      --text:    #1c1a18;
      --muted:   #7a7774;
      --muted2:  #a8a49e;
      --main:    #b8860b;
      --ritual:  #c0392b;
      --chaos:   #c84b00;
      --desert:  #2e7d6e;
      --must:    #d49500;
      --rec:     #3d8050;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
      --shadow:    0 2px 8px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.05);
      --shadow-md: 0 4px 16px rgba(0,0,0,.1), 0 2px 6px rgba(0,0,0,.06);
    }

    html { font-size: 16px; }
    body {
      background: var(--cream);
      color: var(--text);
      font-family: 'Barlow Condensed', sans-serif;
      min-height: 100vh;
      line-height: 1.4;
    }

    /* ── Layout ─────────────────────── */
    .app { display: flex; min-height: 100vh; }
    .sidebar {
      display: none;
      width: 160px;
      flex-shrink: 0;
      flex-direction: column;
      background: var(--card);
      border-right: 1px solid var(--border);
      position: sticky;
      top: 0;
      height: 100vh;
      z-index: 40;
      padding-top: 28px;
    }
    .main { flex: 1; min-width: 0; display: flex; flex-direction: column; }

    @media (min-width: 1024px) {
      .sidebar { display: flex; }
      .topnav  { display: none !important; }
    }

    /* ── Sidebar nav ─────────────────── */
    .sidebar-label {
      padding: 0 20px 12px;
      font-family: 'Oswald', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--muted2);
    }
    .view-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      padding: 10px 20px;
      background: none;
      border: none;
      border-left: 3px solid transparent;
      font-family: 'Oswald', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
      cursor: pointer;
      transition: color .15s, background .15s, border-color .15s;
      text-align: left;
    }
    .view-btn:hover { color: var(--text); background: var(--card2); }
    .view-btn.active { color: var(--text); background: var(--card2); border-left-color: var(--ritual); }
    .view-btn .icon { font-size: 15px; line-height: 1; }

    /* ── Mobile top nav ──────────────── */
    .topnav {
      display: flex;
      height: 44px;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
    }
    .topnav .view-btn {
      flex: 1;
      justify-content: center;
      border-left: none;
      border-bottom: 3px solid transparent;
      padding: 0 8px;
      font-size: 12px;
    }
    .topnav .view-btn.active { background: none; border-bottom-color: var(--ritual); }

    /* ── Day tabs ────────────────────── */
    .tabs-wrap {
      position: sticky;
      top: 44px;
      z-index: 30;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
    }
    @media (min-width: 1024px) { .tabs-wrap { top: 0; } }
    .tabs {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .tabs::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex-shrink: 0;
      padding: 12px 20px;
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      margin-bottom: -1px;
      font-family: 'Oswald', sans-serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      cursor: pointer;
      transition: color .15s, border-color .15s;
      white-space: nowrap;
    }
    .tab-btn:hover { color: var(--text); }
    .tab-btn.active { color: var(--text); border-bottom-color: var(--ritual); }

    /* ── View / section toggling ─────── */
    .view { display: none; }
    .view.active { display: block; }
    .day-section { display: none; }
    .day-section.active { display: block; animation: fadeUp .22s ease; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: none; } }

    /* ── Lineup grid ─────────────────── */
    .stages-grid {
      display: grid;
      grid-template-columns: 1fr;
    }
    @media (min-width: 640px)  { .stages-grid { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 1280px) { .stages-grid { grid-template-columns: repeat(4, 1fr); } }

    .stage-col {
      border-bottom: 1px solid var(--border);
    }
    @media (min-width: 640px) {
      .stage-col { border-right: 1px solid var(--border); }
      .stage-col:nth-child(2n) { border-right: none; }
      .stage-col:nth-child(3),
      .stage-col:nth-child(4) { border-top: 1px solid var(--border); }
      .stage-col:last-child { border-bottom: 0; }
    }
    @media (min-width: 1280px) {
      .stage-col { border-right: 1px solid var(--border); border-top: none !important; }
      .stage-col:nth-child(2n) { border-right: 1px solid var(--border); }
      .stage-col:last-child { border-right: none; border-bottom: none; }
    }

    /* Stage header */
    .s-hdr {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 14px 16px 11px;
      background: var(--card);
      border-bottom: 2px solid var(--border);
    }
    [data-stage="main"]   .s-hdr { border-bottom-color: var(--main); }
    [data-stage="ritual"] .s-hdr { border-bottom-color: var(--ritual); }
    [data-stage="chaos"]  .s-hdr { border-bottom-color: var(--chaos); }
    [data-stage="desert"] .s-hdr { border-bottom-color: var(--desert); }

    .s-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    [data-stage="main"]   .s-dot { background: var(--main); }
    [data-stage="ritual"] .s-dot { background: var(--ritual); }
    [data-stage="chaos"]  .s-dot { background: var(--chaos); }
    [data-stage="desert"] .s-dot { background: var(--desert); }

    .s-name {
      font-family: 'Oswald', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: .15em;
      text-transform: uppercase;
    }
    [data-stage="main"]   .s-name { color: var(--main); }
    [data-stage="ritual"] .s-name { color: var(--ritual); }
    [data-stage="chaos"]  .s-name { color: var(--chaos); }
    [data-stage="desert"] .s-name { color: var(--desert); }

    /* Band list */
    .band-list { padding: 10px 10px 14px; display: flex; flex-direction: column; gap: 6px; }

    .band-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 10px 12px 9px;
      box-shadow: var(--shadow-sm);
      position: relative;
      overflow: hidden;
      transition: box-shadow .15s, transform .12s, background .1s;
    }
    .band-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 3px;
      background: transparent;
      transition: background .15s;
    }
    [data-stage="main"]   .band-card:hover::before { background: var(--main); }
    [data-stage="ritual"] .band-card:hover::before { background: var(--ritual); }
    [data-stage="chaos"]  .band-card:hover::before { background: var(--chaos); }
    [data-stage="desert"] .band-card:hover::before { background: var(--desert); }
    .band-card:hover {
      background: var(--card2);
      box-shadow: var(--shadow);
      transform: translateY(-1px);
    }

    .band-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
    .band-name {
      font-family: 'Oswald', sans-serif;
      font-size: 15px;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--text);
      line-height: 1.2;
    }

    .badge {
      flex-shrink: 0;
      font-family: 'Oswald', sans-serif;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 2px 6px;
      border-radius: 3px;
      color: #fff;
      margin-top: 1px;
    }
    .badge-must { background: var(--must); }
    .badge-rec  { background: var(--rec); }

    .band-time {
      font-family: 'Oswald', sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: .04em;
      margin-top: 3px;
      display: block;
    }

    .genre-tag {
      display: inline-block;
      margin-top: 5px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: .05em;
      text-transform: uppercase;
      padding: 2px 7px;
      border-radius: 3px;
      border: 1px solid;
    }
    .tag-power    { background:#fef3cd; color:#8a6200; border-color:#f5d87a; }
    .tag-thrash   { background:#fff0e0; color:#a04800; border-color:#f5b87a; }
    .tag-death    { background:#fde8e8; color:#8b1a1a; border-color:#e8a0a0; }
    .tag-deathcore{ background:#fde8e8; color:#9b2020; border-color:#e8a0a0; }
    .tag-black    { background:#f0eaf8; color:#5c2d91; border-color:#c9a8e8; }
    .tag-doom     { background:#eaf2e0; color:#3d6020; border-color:#a8cc80; }
    .tag-math     { background:#ede8f8; color:#4a1d91; border-color:#b89ae0; }
    .tag-metalcore{ background:#fdecea; color:#922010; border-color:#e8a090; }
    .tag-hardcore { background:#e6f4ea; color:#1e6830; border-color:#88cc9a; }
    .tag-nu       { background:#e0f4f8; color:#0d6680; border-color:#78c8de; }
    .tag-post     { background:#e6eef8; color:#1a4a8a; border-color:#88aee0; }
    .tag-punk     { background:#fff4e0; color:#8a5000; border-color:#f5c878; }
    .tag-folk     { background:#f4ece0; color:#6a4010; border-color:#d4b080; }
    .tag-prog     { background:#ede6f8; color:#4a1880; border-color:#c0a0e0; }
    .tag-industrial{background:#eaeef2; color:#3a4a5a; border-color:#a0b0c0; }
    .tag-stoner   { background:#f8f0d8; color:#7a6000; border-color:#e0c060; }
    .tag-heavy    { background:#f8e8e8; color:#7a1828; border-color:#e0a0a8; }
    .tag-rock     { background:#f0f0ee; color:#505050; border-color:#c0c0bc; }
    .tag-tbc      { background:#f5f5f3; color:#909090; border-color:#c8c8c0; font-style:italic; border-style:dashed; }
    .tag-other    { background:#f2f2f0; color:#686868; border-color:#c8c8c0; }

    /* ── Timetable ───────────────────── */
    .timetable-scroll { overflow-x: auto; padding-bottom: 48px; }
    .timetable-inner {
      display: flex;
      min-width: 380px;
      position: relative;
    }

    /* Legend */
    .tt-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 20px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      background: var(--card);
    }
    .tt-legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .tt-legend-dot { width: 8px; height: 8px; border-radius: 50%; }

    /* Ruler */
    .t-ruler {
      position: relative;
      width: 46px;
      flex-shrink: 0;
      border-right: 1px solid var(--border);
      background: var(--card);
    }
    .t-mark {
      position: absolute;
      right: 6px;
      transform: translateY(-50%);
      font-family: 'Oswald', sans-serif;
      white-space: nowrap;
      pointer-events: none;
    }
    .t-mark.hour { font-size: 11px; font-weight: 600; color: var(--text); }
    .t-mark.half { font-size: 9px; color: var(--muted2); }

    /* Events area */
    .t-events {
      flex: 1;
      position: relative;
    }
    .t-line {
      position: absolute;
      left: 0; right: 0;
      pointer-events: none;
    }
    .t-line.hour { height: 1px; background: #c8c3b8; }
    .t-line.half { height: 1px; background: #e8e4dd; }

    /* Band blocks */
    .t-band {
      position: absolute;
      border-radius: 6px;
      overflow: hidden;
      padding: 7px 9px 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,.1);
      cursor: default;
      display: flex;
      flex-direction: column;
      gap: 3px;
      transition: filter .12s, z-index 0s, box-shadow .12s;
    }
    .t-band:hover { filter: brightness(.94); z-index: 20; box-shadow: var(--shadow); }
    .t-band[data-stage="main"]   { border-left: 3px solid var(--main);   background: #fef6df; }
    .t-band[data-stage="ritual"] { border-left: 3px solid var(--ritual); background: #fde9e7; }
    .t-band[data-stage="chaos"]  { border-left: 3px solid var(--chaos);  background: #fdeee6; }
    .t-band[data-stage="desert"] { border-left: 3px solid var(--desert); background: #e5f2ef; }

    .t-top-row { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
    .t-stage-pill {
      font-family: 'Oswald', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .07em;
      text-transform: uppercase;
      padding: 2px 6px;
      border-radius: 3px;
      line-height: 1.4;
      flex-shrink: 0;
    }
    .t-badge {
      font-family: 'Oswald', sans-serif;
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: .05em;
      text-transform: uppercase;
      padding: 2px 6px;
      border-radius: 3px;
      color: #fff;
      line-height: 1.4;
      flex-shrink: 0;
    }
    .t-badge.must { background: var(--must); }
    .t-badge.rec  { background: var(--rec); }
    .t-body {
      flex: 1;
      display: flex;
      align-items: center;
      min-height: 0;
      overflow: hidden;
    }
    .t-name {
      font-family: 'Oswald', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      overflow: hidden;
      line-height: 1.2;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }
    .t-time {
      flex-shrink: 0;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      white-space: nowrap;
      line-height: 1;
    }
    .t-genre-tag {
      flex-shrink: 0;
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .04em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 4px;
      border: 1px solid;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 100%;
      line-height: 1.4;
    }

    /* ── Footer ──────────────────────── */
    .footer {
      margin-top: auto;
      padding: 24px 16px;
      text-align: center;
      font-family: 'Oswald', sans-serif;
      font-size: 10px;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--muted2);
      border-top: 1px solid var(--border);
    }

    /* ── Scrollbar ───────────────────── */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: var(--cream); }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
  </style>
</head>

<body>
<div class="app">

  <!-- SIDEBAR (desktop) -->
  <aside class="sidebar">
    <p class="sidebar-label">Navegación</p>
    <button class="view-btn active" data-view="horarios">
      <span class="icon">⏱</span> Horarios
    </button>
    <button class="view-btn" data-view="lineup">
      <span class="icon">☰</span> Lineup
    </button>
  </aside>

  <!-- MAIN -->
  <div class="main">

    <!-- Mobile top nav -->
    <nav class="topnav">
      <button class="view-btn active" data-view="horarios">
        <span class="icon">⏱</span> Horarios
      </button>
      <button class="view-btn" data-view="lineup">
        <span class="icon">☰</span> Lineup
      </button>
    </nav>

    <!-- Day tabs -->
    <div class="tabs-wrap">
      <div class="tabs">
        {days.map((day, i) => (
          <button
            class={`tab-btn${i === 0 ? ' active' : ''}`}
            data-target={day.id}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {day.label}
          </button>
        ))}
      </div>
    </div>

    <!-- ══ LINEUP VIEW ══ -->
    <div id="view-lineup" class="view">
      {days.map((day, di) => (
        <section class={`day-section${di === 0 ? ' active' : ''}`} id={`day-${day.id}`}>
          <div class="stages-grid">
            {day.stages.map(stage => (
              <div class="stage-col" data-stage={stage.id}>
                <div class="s-hdr">
                  <span class="s-dot"></span>
                  <span class="s-name">{stage.label}</span>
                </div>
                <ul class="band-list">
                  {stage.bands.map(band => {
                    const tag = getGenreTag(band.genre);
                    const genre = band.genre.replace(' (Set Especial)', '').replace(' (Ganador concurso)', '');
                    const sched = scheduleMap[band.name];
                    return (
                      <li class="band-card">
                        <div class="band-top">
                          <span class="band-name">{band.name}</span>
                          {band.badge && (
                            <span class={`badge ${band.badge === 'Recomendable' ? 'badge-rec' : 'badge-must'}`}>
                              {band.badge}
                            </span>
                          )}
                        </div>
                        {sched && <span class="band-time">{sched.start} – {sched.end}</span>}
                        <span class={`genre-tag ${tag}`}>{genre}</span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- ══ HORARIOS VIEW ══ -->
    <div id="view-horarios" class="view active">
      {days.map((day, di) => {
        const events = processedSchedule[day.id];
        const minSMin = events.length > 0 ? Math.min(...events.map(e => e.sMin)) : 0;
        const trimTop = Math.max(0, minSMin - 10);
        const dayH = (TOTAL - trimTop) * PX;
        const dayMarks = marks
          .filter(m => m.top >= trimTop * PX)
          .map(m => ({ ...m, top: m.top - trimTop * PX }));
        return (
          <section class={`day-section${di === 0 ? ' active' : ''}`} id={`sched-${day.id}`}>

            <!-- Stage legend -->
            <div class="tt-legend">
              {(['main', 'ritual', 'chaos', 'desert'] as const).map(s => (
                <span class="tt-legend-item">
                  <span class="tt-legend-dot" style={`background:${stageColors[s]}`}></span>
                  {s.toUpperCase()}
                </span>
              ))}
            </div>

            <!-- Timeline -->
            <div class="timetable-scroll">
              <div class="timetable-inner" style={`height:${dayH}px`}>

                <!-- Ruler -->
                <div class="t-ruler" style={`height:${dayH}px`}>
                  {dayMarks.map(m => (
                    <span class={`t-mark ${m.hour ? 'hour' : 'half'}`} style={`top:${m.top}px`}>
                      {m.label}
                    </span>
                  ))}
                </div>

                <!-- Events -->
                <div class="t-events" style={`height:${dayH}px`}>
                  {events.map(ev => {
                    const top  = (ev.sMin - trimTop) * PX;
                    const h    = Math.max(26, (ev.eMin - ev.sMin) * PX);
                    const colW = 100 / ev.numCols;
                    const left = ev.col * colW;
                    const stageColor = stageColors[ev.stage];
                    return (
                      <div
                        class="t-band"
                        data-stage={ev.stage}
                        style={`top:${top}px;height:${h}px;left:calc(${left}% + 3px);width:calc(${colW}% - 6px)`}
                      >
                        <div class="t-top-row">
                          <span class="t-stage-pill" style={`color:${stageColor};background:${stageColor}28`}>
                            {ev.stage.toUpperCase()}
                          </span>
                          {ev.badge && (
                            <span class={`t-badge ${ev.badge === 'Recomendable' ? 'rec' : 'must'}`}>
                              {ev.badge === 'Recomendable' ? 'Rec' : 'Must'}
                            </span>
                          )}
                        </div>
                        {h >= 55 && ev.genre && (
                          <span class={`t-genre-tag ${getGenreTag(ev.genre)}`}>{ev.genre}</span>
                        )}
                        <div class="t-body">
                          <span class="t-name">{ev.name}</span>
                        </div>
                        {h >= 38 && <span class="t-time">{ev.start}–{ev.end}</span>}
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>

          </section>
        );
      })}
    </div>

    <footer class="footer">
      Resurrection Fest MMXXVI &nbsp;·&nbsp; Viveiro, Galicia
    </footer>
  </div>
</div>

<script>
  // View switching
  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');
  const views = document.querySelectorAll<HTMLElement>('.view');
  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.view!;
      viewBtns.forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.view === target));
      views.forEach(v => v.classList.toggle('active', v.id === `view-${target}`));
    });
  });

  // Day tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.target!;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
      document.querySelectorAll('#view-lineup .day-section').forEach(s => s.classList.remove('active'));
      document.getElementById(`day-${target}`)?.classList.add('active');
      document.querySelectorAll('#view-horarios .day-section').forEach(s => s.classList.remove('active'));
      document.getElementById(`sched-${target}`)?.classList.add('active');
    });
  });
</script>
</body>
</html>
