function getGenreTag(genre) {
  const g = genre.toLowerCase();
  if (g.includes('power metal')) return 'tag-power';
  if (g.includes('thrash')) return 'tag-thrash';
  if (g.includes('progressive death') || g.includes('melodic death')) return 'tag-death';
  if (g.includes('deathcore')) return 'tag-deathcore';
  if (g.includes('death metal') || (g.includes('death') && !g.includes('deathcore'))) return 'tag-death';
  if (g.includes('black metal') || g.includes('viking')) return 'tag-black';
  if (g.includes('doom') || g.includes('sludge')) return 'tag-doom';
  if (g.includes('mathcore') || g.includes('math rock') || g.includes('noise metal')) return 'tag-math';
  if (g.includes('metalcore')) return 'tag-metalcore';
  if (g.includes('hardcore')) return 'tag-hardcore';
  if (g.includes('nu-metal') || g.includes('nu metal')) return 'tag-nu';
  if (g.includes('post-hardcore') || g.includes('post hardcore') || g.includes('post-metal') || g.includes('post-rock') || g.includes('post-punk')) return 'tag-post';
  if (g.includes('punk')) return 'tag-punk';
  if (g.includes('folk')) return 'tag-folk';
  if (g.includes('progressive') || g.includes('prog') || g.includes('instrumental')) return 'tag-prog';
  if (g.includes('industrial')) return 'tag-industrial';
  if (g.includes('stoner') || g.includes('psych')) return 'tag-stoner';
  if (g.includes('por confirmar')) return 'tag-tbc';
  if (g.includes('heavy metal') || g.includes('symphonic')) return 'tag-heavy';
  if (g.includes('rock') || g.includes('grunge') || g.includes('indie') || g.includes('blues') || g.includes('alternativo')) return 'tag-rock';
  return 'tag-other';
}

function toMin(str) {
  const [h, m] = str.split(':').map(Number);
  return ((h < 14 ? h + 24 : h) * 60 + m) - (14 * 60 + 30);
}

const PX = 3.5;
const TOTAL = 780;
const H = TOTAL * PX;

const marks = Array.from({ length: TOTAL / 30 + 1 }, (_, i) => {
  const mins = i * 30;
  const abs = 14 * 60 + 30 + mins;
  const hh = String(Math.floor(abs / 60) % 24).padStart(2, '0');
  const mm = String(abs % 60).padStart(2, '0');
  return { label: `${hh}:${mm}`, top: mins * PX, hour: abs % 60 === 0 };
});

const stageColors = { main: '#b8860b', ritual: '#c0392b', chaos: '#c84b00', desert: '#7a6548' };

function processDay(daySched, badgeMap) {
  let events = [];
  for (const [stage, bands] of Object.entries(daySched)) {
    for (const band of bands) {
      const sMin = toMin(band.start);
      const eMin = toMin(band.end);
      events.push({ name: band.name, stage, start: band.start, end: band.end, sMin, eMin, color: stageColors[stage], badge: badgeMap[band.name] || null, genre: genreMap[band.name] || null, col: 0, numCols: 1 });
    }
  }
  events.sort((a, b) => a.sMin - b.sMin || a.eMin - b.eMin);

  // Greedy column assignment
  const colEnds = [-1, -1, -1];
  events.forEach(ev => {
    let c = colEnds.findIndex(e => e <= ev.sMin);
    if (c === -1) c = 0;
    ev.col = c;
    colEnds[c] = ev.eMin;
  });

  // Connected components: transitively overlapping events share numCols
  const ovlp = (a, b) => a.sMin < b.eMin && a.eMin > b.sMin;
  const n = events.length;
  const comp = new Array(n).fill(-1);
  let cid = 0;
  for (let i = 0; i < n; i++) {
    if (comp[i] !== -1) continue;
    const q = [i];
    comp[i] = cid;
    for (let qi = 0; qi < q.length; qi++) {
      const cur = q[qi];
      for (let j = 0; j < n; j++) {
        if (comp[j] === -1 && ovlp(events[cur], events[j])) { comp[j] = cid; q.push(j); }
      }
    }
    cid++;
  }
  const compMax = new Array(cid).fill(0);
  events.forEach((ev, i) => { compMax[comp[i]] = Math.max(compMax[comp[i]], ev.col); });
  events.forEach((ev, i) => { ev.numCols = compMax[comp[i]] + 1; });

  return events;
}

